# Validation test: invalid inputs for all Storage Mover resources.
# Copy to validation-test-invalid.tf and run: terraform plan
# Expected: plan fails with validation errors (name length/format, ID format, etc.)
# Requires main.tf to provide: azurerm_resource_group.example, azurerm_storage_mover.example,
# azurerm_storage_account.example, azurerm_storage_container.example, azurerm_storage_share.nfs,
# azurerm_storage_account.nfs, azurerm_storage_mover_project.example, azurerm_storage_mover_source_endpoint.example

# --- Invalid: endpoint/project/job definition name (must be 1-64 chars, alphanumeric/_-) ---
resource "azurerm_storage_mover_target_endpoint" "invalid_name" {
  name                   = "acctest-smte-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" # 65 chars
  storage_mover_id       = azurerm_storage_mover.example.id
  storage_account_id     = azurerm_storage_account.example.id
  storage_container_name = azurerm_storage_container.example.name
}

# --- Invalid: storage_mover_id must be Microsoft.StorageMover/storageMovers ID ---
resource "azurerm_storage_mover_project" "invalid_storage_mover_id" {
  name             = "valid-project-name"
  storage_mover_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg/providers/Microsoft.Storage/storageAccounts/wrong"
}

# --- Invalid: storage_account_id must be storage account resource ID ---
resource "azurerm_storage_mover_nfs_file_share_endpoint" "invalid_storage_account_id" {
  name               = "valid-nfse-name"
  storage_mover_id   = azurerm_storage_mover.example.id
  storage_account_id = "not-a-valid-resource-id"
  file_share_name    = "valid-share-name"
}

# --- Invalid: file_share_name must be 3-63 chars, lowercase alphanumeric and hyphens ---
resource "azurerm_storage_mover_nfs_file_share_endpoint" "invalid_file_share_name" {
  name               = "valid-nfse-name-2"
  storage_mover_id   = azurerm_storage_mover.example.id
  storage_account_id = azurerm_storage_account.nfs.id
  file_share_name    = "AB"
}

# --- Invalid: storage_container_name must be 3-63 chars, lowercase ---
resource "azurerm_storage_mover_target_endpoint" "invalid_container_name" {
  name                   = "valid-te-name"
  storage_mover_id       = azurerm_storage_mover.example.id
  storage_account_id     = azurerm_storage_account.example.id
  storage_container_name = "x"
}

# --- Invalid: storage_mover_project_id must be Microsoft.StorageMover project ID (not storage mover ID) ---
resource "azurerm_storage_mover_job_definition" "invalid_project_id" {
  name                     = "valid-jd-name"
  storage_mover_project_id  = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg/providers/Microsoft.StorageMover/storageMovers/mover/endpoints/wrong"
  source_name               = azurerm_storage_mover_source_endpoint.example.name
  target_name               = azurerm_storage_mover_target_endpoint.example.name
  copy_mode                 = "Additive"
}

# --- Invalid: copy_mode must be Additive or Mirror ---
resource "azurerm_storage_mover_job_definition" "invalid_copy_mode" {
  name                    = "valid-jd-name-2"
  storage_mover_project_id = azurerm_storage_mover_project.example.id
  source_name             = azurerm_storage_mover_source_endpoint.example.name
  target_name             = azurerm_storage_mover_target_endpoint.example.name
  copy_mode               = "InvalidMode"
}
